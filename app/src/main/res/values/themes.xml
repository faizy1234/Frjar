<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base App Theme (Always Light) -->
    <style name="NightAdjusted.Theme.Nia" parent="android:Theme.Material.Light.NoActionBar">

        <!-- Force White Background -->
        <item name="android:windowBackground">@android:color/white</item>

        <!-- Disable Force Dark -->
        <item name="android:forceDarkAllowed" tools:targetApi="29">false</item>

        <!-- Status & Navigation bar light icons -->
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

    </style>

    <!-- Final App Theme -->
    <style name="Theme.Nia" parent="NightAdjusted.Theme.Nia" />



    <!-- Splash Base Theme -->
    <style name="NightAdjusted.Theme.Splash" parent="Theme.SplashScreen">

        <!-- Force White Splash Background -->
        <item name="windowSplashScreenBackground">@android:color/white</item>

        <!-- Splash Icon -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_round</item>

        <!-- Disable Force Dark -->
        <item name="android:forceDarkAllowed" tools:targetApi="29">false</item>

        <!-- Light Status & Navigation -->
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

    </style>

    <!-- Final Splash Theme -->
    <style name="Theme.Nia.Splash" parent="NightAdjusted.Theme.Splash">
        <item name="postSplashScreenTheme">@style/Theme.Nia</item>
    </style>



    <!-- Alias for Manifest -->
    <style name="Theme.FrjarCustomer" parent="Theme.Nia" />

</resources>